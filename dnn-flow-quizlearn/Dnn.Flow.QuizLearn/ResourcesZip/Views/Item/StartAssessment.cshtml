@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Dnn.Flow.QuizLearn.Models.AssessmentStartViewModel>
<link rel="stylesheet" href="/DesktopModules/YourRfProjects/dnn-flow-quizlearn/Dnn.Flow.QuizLearn/css/quizlearn.css" />
<script>
    (function () {
        var params = new URLSearchParams(window.location.search);
        var languageId = params.get("languageId");

        if (!languageId) return;

        var languageInput = document.querySelector('input[name="LanguageId"][value="' + languageId + '"]');

        if (languageInput) {
            languageInput.checked = true;
        }
    })();
</script>

<div class="quizlearn-wrapper">
    <div class="quizlearn-card">

        <div class="quizlearn-step-indicator">
            <span class="active">1</span>
            <span>2</span>
            <span>3</span>
        </div>

        <h2 class="quizlearn-title">Szintfelmérő indítása</h2>

        <p class="quizlearn-description">
            A szintfelmérő segít meghatározni, hogy jelenleg milyen nyelvi szinten vagy.
        </p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="quizlearn-error">
                @foreach (var state in ViewData.ModelState.Values)
                {
                    foreach (var error in state.Errors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                }
            </div>
        }

        <form method="post" class="quizlearn-form">
            @Html.AntiForgeryToken()

            <input type="hidden" name="AssessmentAction" value="StartLevelTest" />

            @if (Model.HasExistingSession)
            {
                <input type="hidden" name="SessionId" value="@Model.SessionId" />
                <input type="hidden" name="LanguageId" value="@Model.LanguageId" />

                <p class="quizlearn-description">
                    A szintfelmérő a korábban kiválasztott nyelv alapján indul.
                </p>
            }
            else
            {
                <div class="quizlearn-field">
                    <label for="LanguageId">Milyen nyelvből szeretnél szintfelmérőt?</label>

                    <select id="LanguageId" name="LanguageId" class="quizlearn-select">
                        <option value="">-- Válassz nyelvet --</option>

                        @foreach (var language in Model.Languages)
                        {
                            <option value="@language.LanguageId">@language.Name</option>
                        }
                    </select>
                </div>
            }

            <button type="submit" class="quizlearn-button">
                Szintfelmérő indítása
            </button>
        </form>
    </div>
</div>
