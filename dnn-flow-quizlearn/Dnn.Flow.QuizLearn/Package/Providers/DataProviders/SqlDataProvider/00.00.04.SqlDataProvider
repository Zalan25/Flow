/* ---------------------------------------------
   lm_TestAttempts_Start
   --------------------------------------------- */

IF EXISTS (
    SELECT *
    FROM sysobjects
    WHERE id = OBJECT_ID(N'{databaseOwner}[{objectQualifier}lm_TestAttempts_Start]')
      AND type = 'P'
)
    DROP PROCEDURE {databaseOwner}[{objectQualifier}lm_TestAttempts_Start]
GO

CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_TestAttempts_Start]
    @ModuleId INT,
    @AssessmentSessionId INT,
    @TestId INT
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @AttemptNumber INT;

    SELECT @AttemptNumber = ISNULL(MAX([AttemptNumber]), 0) + 1
    FROM {databaseOwner}[{objectQualifier}lm_test_attempts]
    WHERE [AssessmentSessionId] = @AssessmentSessionId;

    INSERT INTO {databaseOwner}[{objectQualifier}lm_test_attempts]
    (
        [ModuleId],
        [AssessmentSessionId],
        [TestId],
        [StartedOn],
        [IsCompleted],
        [TotalScore],
        [AttemptNumber]
    )
    VALUES
    (
        @ModuleId,
        @AssessmentSessionId,
        @TestId,
        SYSUTCDATETIME(),
        0,
        0,
        @AttemptNumber
    );

    SELECT CAST(SCOPE_IDENTITY() AS INT) AS [TestAttemptId];
END
GO


