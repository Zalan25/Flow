/* ---------------------------------------------
   lm_Questions_GetForAssessment
   --------------------------------------------- */

IF EXISTS (
    SELECT *
    FROM sysobjects
    WHERE id = OBJECT_ID(N'{databaseOwner}[{objectQualifier}lm_Questions_GetForAssessment]')
      AND type = 'P'
)
    DROP PROCEDURE {databaseOwner}[{objectQualifier}lm_Questions_GetForAssessment]
GO

CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_Questions_GetForAssessment]
    @ModuleId INT,
    @LanguageId INT
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        [QuestionId],
        [ModuleId],
        [QuestionText],
        [LanguageId],
        [QuestionLevelId],
        [QuestionTypeId],
        [SkillTypeId],
        [Points],
        [IsActive]
    FROM {databaseOwner}[{objectQualifier}lm_questions]
    WHERE ([ModuleId] = @ModuleId OR [ModuleId] = 0)
      AND [LanguageId] = @LanguageId
      AND [IsActive] = 1
    ORDER BY
        CASE WHEN [ModuleId] = @ModuleId THEN 0 ELSE 1 END,
        [QuestionLevelId],
        [QuestionId];
END
GO


