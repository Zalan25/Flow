/* ---------------------------------------------
   lm_Languages_GetAllActive
   --------------------------------------------- */

IF EXISTS (
    SELECT *
    FROM sysobjects
    WHERE id = OBJECT_ID(N'{databaseOwner}[{objectQualifier}lm_Languages_GetAllActive]')
      AND type = 'P'
)
    DROP PROCEDURE {databaseOwner}[{objectQualifier}lm_Languages_GetAllActive]
GO

CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_Languages_GetAllActive]
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        [LanguageId],
        [Name],
        [Code],
        [IsActive]
    FROM {databaseOwner}[{objectQualifier}lm_languages]
    WHERE [IsActive] = 1
    ORDER BY [Name];
END
