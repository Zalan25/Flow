/* ---------------------------------------------
   lm_AssessmentSessions_Add
   --------------------------------------------- */

IF EXISTS (
    SELECT *
    FROM sysobjects
    WHERE id = OBJECT_ID(N'{databaseOwner}[{objectQualifier}lm_AssessmentSessions_Add]')
      AND type = 'P'
)
    DROP PROCEDURE {databaseOwner}[{objectQualifier}lm_AssessmentSessions_Add]
GO

CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_AssessmentSessions_Add]
    @ModuleId            INT,
    @AssessmentModeId    INT,
    @LanguageId          INT,
    @SecondaryLanguageId INT = NULL,
    @SelectedLevelId     INT = NULL,
    @PaceTypeId          INT = NULL,
    @UserId              INT = NULL,
    @NeedLevelTest       BIT = 0,
    @Status              NVARCHAR(50) = 'Started'
AS
BEGIN
    SET NOCOUNT ON;

    INSERT INTO {databaseOwner}[{objectQualifier}lm_assessment_sessions]
    (
        [ModuleId],
        [AssessmentModeId],
        [LanguageId],
        [SecondaryLanguageId],
        [SelectedLevelId],
        [PaceTypeId],
        [UserId],
        [NeedLevelTest],
        [Status]
    )
    VALUES
    (
        @ModuleId,
        @AssessmentModeId,
        @LanguageId,
        @SecondaryLanguageId,
        @SelectedLevelId,
        @PaceTypeId,
        @UserId,
        @NeedLevelTest,
        @Status
    );

    SELECT CAST(SCOPE_IDENTITY() AS INT) AS [AssessmentSessionId];
END
GO


/* ---------------------------------------------
   lm_AssessmentSessionSkills_Add
   --------------------------------------------- */

IF EXISTS (
    SELECT *
    FROM sysobjects
    WHERE id = OBJECT_ID(N'{databaseOwner}[{objectQualifier}lm_AssessmentSessionSkills_Add]')
      AND type = 'P'
)
    DROP PROCEDURE {databaseOwner}[{objectQualifier}lm_AssessmentSessionSkills_Add]
GO

CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_AssessmentSessionSkills_Add]
    @ModuleId            INT,
    @AssessmentSessionId INT,
    @SkillTypeId         INT
AS
BEGIN
    SET NOCOUNT ON;

    IF EXISTS (
        SELECT 1
        FROM {databaseOwner}[{objectQualifier}lm_assessment_session_skills]
        WHERE [AssessmentSessionId] = @AssessmentSessionId
          AND [SkillTypeId] = @SkillTypeId
    )
    BEGIN
        SELECT [AssessmentSessionSkillId]
        FROM {databaseOwner}[{objectQualifier}lm_assessment_session_skills]
        WHERE [AssessmentSessionId] = @AssessmentSessionId
          AND [SkillTypeId] = @SkillTypeId;
    END
    ELSE
    BEGIN
        INSERT INTO {databaseOwner}[{objectQualifier}lm_assessment_session_skills]
        (
            [ModuleId],
            [AssessmentSessionId],
            [SkillTypeId]
        )
        VALUES
        (
            @ModuleId,
            @AssessmentSessionId,
            @SkillTypeId
        );

        SELECT CAST(SCOPE_IDENTITY() AS INT) AS [AssessmentSessionSkillId];
    END
END
GO


/* ---------------------------------------------
   lm_RecommendationRules_FindExact
   --------------------------------------------- */

IF EXISTS (
    SELECT *
    FROM sysobjects
    WHERE id = OBJECT_ID(N'{databaseOwner}[{objectQualifier}lm_RecommendationRules_FindExact]')
      AND type = 'P'
)
    DROP PROCEDURE {databaseOwner}[{objectQualifier}lm_RecommendationRules_FindExact]
GO

CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_RecommendationRules_FindExact]
    @ModuleId            INT,
    @LanguageId          INT,
    @QuestionLevelId     INT,
    @SkillTypeId         INT,
    @PaceTypeId          INT,
    @SecondaryLanguageId INT = NULL
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        [RecommendationRuleId],
        [ModuleId],
        [LanguageId],
        [QuestionLevelId],
        [SkillTypeId],
        [SecondaryLanguageId],
        [PaceTypeId],
        [Priority],
        [MatchMode],
        [HotcakesProductSKU],
        [HotcakesCategoryKey],
        [HotcakesTag],
        [MinProducts],
        [MaxProducts],
        [IsActive]
    FROM {databaseOwner}[{objectQualifier}lm_recommendation_rules]
    WHERE ([ModuleId] = @ModuleId OR [ModuleId] = 0)
      AND [LanguageId] = @LanguageId
      AND [QuestionLevelId] = @QuestionLevelId
      AND [SkillTypeId] = @SkillTypeId
      AND [PaceTypeId] = @PaceTypeId
      AND [MatchMode] = 'EXACT'
      AND [IsActive] = 1
      AND (
            (@SecondaryLanguageId IS NULL AND [SecondaryLanguageId] IS NULL)
            OR [SecondaryLanguageId] = @SecondaryLanguageId
          )
    ORDER BY
        CASE WHEN [ModuleId] = @ModuleId THEN 0 ELSE 1 END,
        [Priority];
END
GO


