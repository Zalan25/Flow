/* ---------------------------------------------
   lm_TestAttemptAnswers_AddSingle
   --------------------------------------------- */

IF EXISTS (
    SELECT *
    FROM sysobjects
    WHERE id = OBJECT_ID(N'{databaseOwner}[{objectQualifier}lm_TestAttemptAnswers_AddSingle]')
      AND type = 'P'
)
    DROP PROCEDURE {databaseOwner}[{objectQualifier}lm_TestAttemptAnswers_AddSingle]
GO

CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_TestAttemptAnswers_AddSingle]
    @ModuleId INT,
    @AssessmentSessionId INT,
    @QuestionId INT,
    @SelectedAnswerId INT
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @TestAttemptId INT;
    DECLARE @TestAttemptAnswerId INT;
    DECLARE @IsCorrect BIT;
    DECLARE @EarnedPoints INT;

    SELECT TOP 1
        @TestAttemptId = [TestAttemptId]
    FROM {databaseOwner}[{objectQualifier}lm_test_attempts]
    WHERE [ModuleId] = @ModuleId
      AND [AssessmentSessionId] = @AssessmentSessionId
      AND [IsCompleted] = 0
    ORDER BY [TestAttemptId] DESC;

    IF @TestAttemptId IS NULL
    BEGIN
        RAISERROR('No active test attempt found.', 16, 1);
        RETURN;
    END;

    SELECT
        @IsCorrect = a.[IsCorrect],
        @EarnedPoints =
            CASE WHEN a.[IsCorrect] = 1 THEN q.[Points] ELSE 0 END
    FROM {databaseOwner}[{objectQualifier}lm_answers] a
    INNER JOIN {databaseOwner}[{objectQualifier}lm_questions] q
        ON q.[QuestionId] = a.[QuestionId]
    WHERE (a.[ModuleId] = @ModuleId OR a.[ModuleId] = 0)
      AND (q.[ModuleId] = @ModuleId OR q.[ModuleId] = 0)
      AND a.[QuestionId] = @QuestionId
      AND a.[AnswerId] = @SelectedAnswerId;

    IF @IsCorrect IS NULL
    BEGIN
        RAISERROR('Selected answer does not belong to the given question.', 16, 1);
        RETURN;
    END;

    IF EXISTS (
        SELECT 1
        FROM {databaseOwner}[{objectQualifier}lm_test_attempt_answers]
        WHERE [ModuleId] = @ModuleId
          AND [TestAttemptId] = @TestAttemptId
          AND [QuestionId] = @QuestionId
    )
    BEGIN
        UPDATE {databaseOwner}[{objectQualifier}lm_test_attempt_answers]
        SET
            [SelectedAnswerId] = @SelectedAnswerId,
            [TextAnswer] = NULL,
            [IsCorrect] = @IsCorrect,
            [EarnedPoints] = @EarnedPoints,
            [IsAutoGraded] = 1,
            [RequiresManualReview] = 0,
            [AnsweredOn] = SYSUTCDATETIME()
        WHERE [ModuleId] = @ModuleId
          AND [TestAttemptId] = @TestAttemptId
          AND [QuestionId] = @QuestionId;

        SELECT
            @TestAttemptAnswerId = [TestAttemptAnswerId]
        FROM {databaseOwner}[{objectQualifier}lm_test_attempt_answers]
        WHERE [ModuleId] = @ModuleId
          AND [TestAttemptId] = @TestAttemptId
          AND [QuestionId] = @QuestionId;

        DELETE FROM {databaseOwner}[{objectQualifier}lm_test_attempt_answer_options]
        WHERE [ModuleId] = @ModuleId
          AND [TestAttemptAnswerId] = @TestAttemptAnswerId;
    END
    ELSE
    BEGIN
        INSERT INTO {databaseOwner}[{objectQualifier}lm_test_attempt_answers]
        (
            [ModuleId],
            [TestAttemptId],
            [QuestionId],
            [SelectedAnswerId],
            [TextAnswer],
            [IsCorrect],
            [EarnedPoints],
            [IsAutoGraded],
            [RequiresManualReview],
            [AnsweredOn]
        )
        VALUES
        (
            @ModuleId,
            @TestAttemptId,
            @QuestionId,
            @SelectedAnswerId,
            NULL,
            @IsCorrect,
            @EarnedPoints,
            1,
            0,
            SYSUTCDATETIME()
        );

        SET @TestAttemptAnswerId = CAST(SCOPE_IDENTITY() AS INT);
    END;

    INSERT INTO {databaseOwner}[{objectQualifier}lm_test_attempt_answer_options]
    (
        [ModuleId],
        [TestAttemptAnswerId],
        [AnswerId],
        [IsSelected]
    )
    VALUES
    (
        @ModuleId,
        @TestAttemptAnswerId,
        @SelectedAnswerId,
        1
    );

    SELECT @TestAttemptAnswerId AS [TestAttemptAnswerId];
END
GO


