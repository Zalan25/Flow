CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_TestAttemptAnswers_AddText]
    @ModuleId INT,
    @AssessmentSessionId INT,
    @QuestionId INT,
    @TextAnswer NVARCHAR(MAX)
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @TestAttemptId INT;
    DECLARE @TestAttemptAnswerId INT;
    DECLARE @IsCorrect BIT;
    DECLARE @EarnedPoints INT;
    DECLARE @QuestionPoints INT;

    SELECT TOP 1
        @TestAttemptId = [TestAttemptId]
    FROM {databaseOwner}[{objectQualifier}lm_test_attempts]
    WHERE [ModuleId] = @ModuleId
      AND [AssessmentSessionId] = @AssessmentSessionId
      AND [IsCompleted] = 0
    ORDER BY [TestAttemptId] DESC;

    IF @TestAttemptId IS NULL
    BEGIN
        RAISERROR('No active test attempt found.', 16, 1);
        RETURN;
    END;

    SELECT
        @QuestionPoints = [Points]
    FROM {databaseOwner}[{objectQualifier}lm_questions]
    WHERE ([ModuleId] = @ModuleId OR [ModuleId] = 0)
      AND [QuestionId] = @QuestionId;

    IF EXISTS (
        SELECT 1
        FROM {databaseOwner}[{objectQualifier}lm_answers]
        WHERE ([ModuleId] = @ModuleId OR [ModuleId] = 0)
          AND [QuestionId] = @QuestionId
          AND [IsCorrect] = 1
          AND LOWER(LTRIM(RTRIM(@TextAnswer))) LIKE '%' + LOWER(LTRIM(RTRIM([AnswerText]))) + '%'
    )
    BEGIN
        SET @IsCorrect = 1;
        SET @EarnedPoints = ISNULL(@QuestionPoints, 0);
    END
    ELSE
    BEGIN
        SET @IsCorrect = 0;
        SET @EarnedPoints = 0;
    END;

    IF EXISTS (
        SELECT 1
        FROM {databaseOwner}[{objectQualifier}lm_test_attempt_answers]
        WHERE [ModuleId] = @ModuleId
          AND [TestAttemptId] = @TestAttemptId
          AND [QuestionId] = @QuestionId
    )
    BEGIN
        UPDATE {databaseOwner}[{objectQualifier}lm_test_attempt_answers]
        SET
            [SelectedAnswerId] = NULL,
            [TextAnswer] = @TextAnswer,
            [IsCorrect] = @IsCorrect,
            [EarnedPoints] = @EarnedPoints,
            [IsAutoGraded] = 1,
            [RequiresManualReview] = 0,
            [AnsweredOn] = SYSUTCDATETIME()
        WHERE [ModuleId] = @ModuleId
          AND [TestAttemptId] = @TestAttemptId
          AND [QuestionId] = @QuestionId;

        SELECT
            @TestAttemptAnswerId = [TestAttemptAnswerId]
        FROM {databaseOwner}[{objectQualifier}lm_test_attempt_answers]
        WHERE [ModuleId] = @ModuleId
          AND [TestAttemptId] = @TestAttemptId
          AND [QuestionId] = @QuestionId;

        DELETE FROM {databaseOwner}[{objectQualifier}lm_test_attempt_answer_options]
        WHERE [ModuleId] = @ModuleId
          AND [TestAttemptAnswerId] = @TestAttemptAnswerId;

        SELECT @TestAttemptAnswerId AS [TestAttemptAnswerId];
        RETURN;
    END;

    INSERT INTO {databaseOwner}[{objectQualifier}lm_test_attempt_answers]
    (
        [ModuleId],
        [TestAttemptId],
        [QuestionId],
        [SelectedAnswerId],
        [TextAnswer],
        [IsCorrect],
        [EarnedPoints],
        [IsAutoGraded],
        [RequiresManualReview],
        [AnsweredOn]
    )
    VALUES
    (
        @ModuleId,
        @TestAttemptId,
        @QuestionId,
        NULL,
        @TextAnswer,
        @IsCorrect,
        @EarnedPoints,
        1,
        0,
        SYSUTCDATETIME()
    );

    SELECT CAST(SCOPE_IDENTITY() AS INT) AS [TestAttemptAnswerId];
END
