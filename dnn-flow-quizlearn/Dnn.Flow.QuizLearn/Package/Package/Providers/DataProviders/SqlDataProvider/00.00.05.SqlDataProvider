CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_TestAttemptAnswerOptions_Add]
    @ModuleId INT,
    @TestAttemptAnswerId INT,
    @AnswerId INT
AS
BEGIN
    SET NOCOUNT ON;

    IF NOT EXISTS (
        SELECT 1
        FROM {databaseOwner}[{objectQualifier}lm_test_attempt_answers] taa
        INNER JOIN {databaseOwner}[{objectQualifier}lm_answers] a
            ON a.[QuestionId] = taa.[QuestionId]
           AND a.[AnswerId] = @AnswerId
        WHERE taa.[ModuleId] = @ModuleId
          AND taa.[TestAttemptAnswerId] = @TestAttemptAnswerId
          AND (a.[ModuleId] = @ModuleId OR a.[ModuleId] = 0)
    )
