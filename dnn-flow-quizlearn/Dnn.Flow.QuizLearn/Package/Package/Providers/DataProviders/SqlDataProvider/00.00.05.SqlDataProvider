        RAISERROR('Selected answer does not belong to the given test attempt answer question.', 16, 1);
        RETURN;
    END;

    IF NOT EXISTS (
        SELECT 1
        FROM {databaseOwner}[{objectQualifier}lm_test_attempt_answer_options]
