            [TestAttemptAnswerId],
            [AnswerId],
            [IsSelected]
        )
        VALUES
        (
            @ModuleId,
            @TestAttemptAnswerId,
            @AnswerId,
            1
        );
    END;

    SELECT [TestAttemptAnswerOptionId]
    FROM {databaseOwner}[{objectQualifier}lm_test_attempt_answer_options]
