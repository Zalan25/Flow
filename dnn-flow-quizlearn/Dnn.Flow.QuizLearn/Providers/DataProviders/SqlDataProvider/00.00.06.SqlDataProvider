CREATE PROCEDURE dbo.lm_AssessmentSessionQuestions_Generate
    @ModuleId INT,
    @AssessmentSessionId INT,
    @LanguageId INT
AS
BEGIN
    SET NOCOUNT ON;

    DELETE FROM dbo.lm_assessment_session_questions
    WHERE AssessmentSessionId = @AssessmentSessionId;

    DECLARE @order INT = 1;

    -- A1
    INSERT INTO dbo.lm_assessment_session_questions
    SELECT TOP 5
        @ModuleId,
        @AssessmentSessionId,
        QuestionId,
        ROW_NUMBER() OVER (ORDER BY NEWID()) + @order - 1
    FROM dbo.lm_questions
    WHERE ModuleId = @ModuleId AND LanguageId = @LanguageId AND QuestionLevelId = 1
    ORDER BY NEWID();

    SET @order += 5;

    -- A2
    INSERT INTO dbo.lm_assessment_session_questions
    SELECT TOP 5
        @ModuleId,
        @AssessmentSessionId,
        QuestionId,
        ROW_NUMBER() OVER (ORDER BY NEWID()) + @order - 1
    FROM dbo.lm_questions
    WHERE ModuleId = @ModuleId AND LanguageId = @LanguageId AND QuestionLevelId = 2
    ORDER BY NEWID();

    SET @order += 5;

    -- B1
    INSERT INTO dbo.lm_assessment_session_questions
    SELECT TOP 5
        @ModuleId,
        @AssessmentSessionId,
        QuestionId,
        ROW_NUMBER() OVER (ORDER BY NEWID()) + @order - 1
    FROM dbo.lm_questions
    WHERE ModuleId = @ModuleId AND LanguageId = @LanguageId AND QuestionLevelId = 3
    ORDER BY NEWID();

    SET @order += 5;

    -- B2
    INSERT INTO dbo.lm_assessment_session_questions
    SELECT TOP 3
        @ModuleId,
        @AssessmentSessionId,
        QuestionId,
        ROW_NUMBER() OVER (ORDER BY NEWID()) + @order - 1
    FROM dbo.lm_questions
    WHERE ModuleId = @ModuleId AND LanguageId = @LanguageId AND QuestionLevelId = 4
    ORDER BY NEWID();

    SET @order += 3;

    -- C1
    INSERT INTO dbo.lm_assessment_session_questions
    SELECT TOP 2
        @ModuleId,
        @AssessmentSessionId,
        QuestionId,
        ROW_NUMBER() OVER (ORDER BY NEWID()) + @order - 1
    FROM dbo.lm_questions
    WHERE ModuleId = @ModuleId AND LanguageId = @LanguageId AND QuestionLevelId = 5
    ORDER BY NEWID();
END
GO

