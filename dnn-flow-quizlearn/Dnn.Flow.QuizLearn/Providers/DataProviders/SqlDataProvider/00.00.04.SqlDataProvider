CREATE PROCEDURE {databaseOwner}{objectQualifier}lm_Questions_GetForAssessment
    @ModuleId INT,
    @LanguageId INT
AS
BEGIN
    SELECT *
    FROM {databaseOwner}{objectQualifier}lm_questions
    WHERE ModuleId = @ModuleId
      AND LanguageId = @LanguageId
      AND IsActive = 1
    ORDER BY QuestionLevelId, QuestionId;
END
GO

CREATE PROCEDURE {databaseOwner}{objectQualifier}lm_Answers_GetByQuestionId
    @ModuleId INT,
    @QuestionId INT
AS
BEGIN
    SELECT *
    FROM {databaseOwner}{objectQualifier}lm_answers
    WHERE ModuleId = @ModuleId
      AND QuestionId = @QuestionId
    ORDER BY AnswerOrder, AnswerId;
END
GO
