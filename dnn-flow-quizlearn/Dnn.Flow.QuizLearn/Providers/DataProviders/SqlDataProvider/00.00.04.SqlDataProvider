CREATE PROCEDURE dbo.[lm_AssessmentSessionSkills_Add]
    @ModuleId            INT,
    @AssessmentSessionId INT,
    @SkillTypeId         INT
AS
BEGIN
    SET NOCOUNT ON;

    IF EXISTS (
        SELECT 1
        FROM dbo.[lm_assessment_session_skills]
        WHERE [AssessmentSessionId] = @AssessmentSessionId
          AND [SkillTypeId]         = @SkillTypeId
    )
    BEGIN
        SELECT [AssessmentSessionSkillId]
        FROM dbo.[lm_assessment_session_skills]
        WHERE [AssessmentSessionId] = @AssessmentSessionId
          AND [SkillTypeId]         = @SkillTypeId;
    END
    ELSE
    BEGIN
        INSERT INTO dbo.[lm_assessment_session_skills]
        (
            [ModuleId],
            [AssessmentSessionId],
            [SkillTypeId]
        )
        VALUES
        (
            @ModuleId,
            @AssessmentSessionId,
            @SkillTypeId
        );

        SELECT CAST(SCOPE_IDENTITY() AS INT) AS [AssessmentSessionSkillId];
    END
END
GO


/* ---------------------------------------------
   lm_RecommendationRules_FindExact
   --------------------------------------------- */

IF EXISTS (SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'dbo.[lm_RecommendationRules_FindExact]') AND type = 'P')
    DROP PROCEDURE dbo.[lm_RecommendationRules_FindExact]
GO

CREATE PROCEDURE dbo.[lm_RecommendationRules_FindExact]
    @ModuleId            INT,
    @LanguageId          INT,
    @QuestionLevelId     INT,
    @SkillTypeId         INT,
    @PaceTypeId          INT,
    @SecondaryLanguageId INT = NULL
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        [RecommendationRuleId],
        [ModuleId],
        [LanguageId],
        [QuestionLevelId],
        [SkillTypeId],
        [SecondaryLanguageId],
        [PaceTypeId],
        [Priority],
        [MatchMode],
        [HotcakesProductSKU],
        [HotcakesCategoryKey],
        [HotcakesTag],
        [MinProducts],
        [MaxProducts]
    FROM dbo.[lm_recommendation_rules]
    WHERE [ModuleId]        = @ModuleId
      AND [LanguageId]      = @LanguageId
      AND [QuestionLevelId] = @QuestionLevelId
      AND [SkillTypeId]     = @SkillTypeId
      AND [PaceTypeId]      = @PaceTypeId
      AND [MatchMode]       = 'EXACT'
      AND [IsActive]        = 1
      AND (
            (@SecondaryLanguageId IS NULL AND [SecondaryLanguageId] IS NULL)
            OR [SecondaryLanguageId] = @SecondaryLanguageId
          )
    ORDER BY [Priority];
END
GO


