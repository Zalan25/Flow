   lm_AssessmentSessions_Complete
   --------------------------------------------- */

IF EXISTS (SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'dbo.[lm_AssessmentSessions_Complete]') AND type = 'P')
    DROP PROCEDURE dbo.[lm_AssessmentSessions_Complete]
GO

CREATE PROCEDURE dbo.[lm_AssessmentSessions_Complete]
    @ModuleId            INT,
    @AssessmentSessionId INT,
    @FinalLevelId        INT = NULL
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE dbo.[lm_assessment_sessions]
    SET
        [Status]       = 'Completed',
        [FinalLevelId] = @FinalLevelId,
        [CompletedOn]  = SYSUTCDATETIME()
    WHERE [AssessmentSessionId] = @AssessmentSessionId
      AND [ModuleId]            = @ModuleId;

    SELECT @@ROWCOUNT AS [AffectedRows];
END
GO

