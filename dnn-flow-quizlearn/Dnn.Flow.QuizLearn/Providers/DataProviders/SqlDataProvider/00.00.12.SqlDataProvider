/* Fail loudly if a lookup value is missing. This prevents silent partial seeds. */
IF EXISTS (
    SELECT 1
    FROM @ProductSeed ps
    LEFT JOIN {databaseOwner}[{objectQualifier}lm_languages] l
        ON l.[Code] = ps.[LanguageCode]
    LEFT JOIN {databaseOwner}[{objectQualifier}lm_question_levels] ql
        ON ql.[LevelName] = ps.[LevelName]
    LEFT JOIN {databaseOwner}[{objectQualifier}lm_skill_types] st
        ON st.[SkillName] = ps.[SkillName]
    WHERE l.[LanguageId] IS NULL
       OR ql.[QuestionLevelId] IS NULL
       OR st.[SkillTypeId] IS NULL
)
BEGIN
    RAISERROR('Missing lookup value for exact recommendation product seed.', 16, 1);
    RETURN;
END;

;WITH RankedSource AS
(
    SELECT
        ps.[SourceOrder],
        ps.[LanguageCode],
        ps.[LevelName],
        ps.[SkillName],
        ps.[ProductKind],
        ps.[HotcakesProductSKU],
        ROW_NUMBER() OVER (
            PARTITION BY ps.[LanguageCode], ps.[LevelName], ps.[SkillName]
            ORDER BY ps.[SourceOrder]
        ) AS [Priority]
    FROM @ProductSeed ps
)
INSERT INTO {databaseOwner}[{objectQualifier}lm_recommendation_rules]
(
    [ModuleId],
    [LanguageId],
    [QuestionLevelId],
    [SkillTypeId],
    [SecondaryLanguageId],
    [PaceTypeId],
    [Priority],
    [MatchMode],
    [HotcakesProductSKU],
    [HotcakesCategoryKey],
    [HotcakesTag],
    [ProductKind],
    [MinProducts],
    [MaxProducts],
    [IsActive]
)
SELECT
    @ModuleId,
    l.[LanguageId],
    ql.[QuestionLevelId],
    st.[SkillTypeId],
    NULL,
    pt.[PaceTypeId],
    rs.[Priority],
    N'EXACT',
    rs.[HotcakesProductSKU],
    NULL,
    NULL,
    rs.[ProductKind],
    pt.[MinProducts],
    pt.[MaxProducts],
    1
FROM RankedSource rs
INNER JOIN {databaseOwner}[{objectQualifier}lm_languages] l
    ON l.[Code] = rs.[LanguageCode]
INNER JOIN {databaseOwner}[{objectQualifier}lm_question_levels] ql
    ON ql.[LevelName] = rs.[LevelName]
INNER JOIN {databaseOwner}[{objectQualifier}lm_skill_types] st
    ON st.[SkillName] = rs.[SkillName]
INNER JOIN {databaseOwner}[{objectQualifier}lm_pace_types] pt
    ON pt.[IsActive] = 1
WHERE l.[IsActive] = 1;
