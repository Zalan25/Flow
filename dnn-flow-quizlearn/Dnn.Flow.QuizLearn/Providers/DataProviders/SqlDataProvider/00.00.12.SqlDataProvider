/*****       Seeds EXACT recommendation rules from      *****/
/*****       bundle.docx product mapping.               *****/
/************************************************************/
IF OBJECT_ID(N'{databaseOwner}[{objectQualifier}lm_product_mappings]', N'U') IS NULL
BEGIN
    CREATE TABLE {databaseOwner}[{objectQualifier}lm_product_mappings]
    (
        [ProductMappingId] INT IDENTITY(1,1) NOT NULL,
        [ModuleId] INT NOT NULL,
        [HotcakesProductSKU] NVARCHAR(100) NOT NULL,
        [LanguageId] INT NOT NULL,
        [QuestionLevelId] INT NULL,
        [SkillTypeId] INT NOT NULL,
        [ProductKind] NVARCHAR(50) NULL,
        [Priority] INT NOT NULL CONSTRAINT [DF_{objectQualifier}lm_pm_Priority] DEFAULT 100,
        [IsActive] BIT NOT NULL CONSTRAINT [DF_{objectQualifier}lm_pm_IsActive] DEFAULT 1,

        CONSTRAINT [PK_{objectQualifier}lm_product_mappings]
            PRIMARY KEY CLUSTERED ([ProductMappingId]),

        CONSTRAINT [FK_{objectQualifier}lm_pm_LanguageId]
            FOREIGN KEY ([LanguageId])
            REFERENCES {databaseOwner}[{objectQualifier}lm_languages]([LanguageId]),

        CONSTRAINT [FK_{objectQualifier}lm_pm_QuestionLevelId]
            FOREIGN KEY ([QuestionLevelId])
            REFERENCES {databaseOwner}[{objectQualifier}lm_question_levels]([QuestionLevelId]),

        CONSTRAINT [FK_{objectQualifier}lm_pm_SkillTypeId]
            FOREIGN KEY ([SkillTypeId])
            REFERENCES {databaseOwner}[{objectQualifier}lm_skill_types]([SkillTypeId]),

        CONSTRAINT [UQ_{objectQualifier}lm_pm_unique]
            UNIQUE ([ModuleId], [HotcakesProductSKU], [LanguageId], [QuestionLevelId], [SkillTypeId])
    );
END
GO

IF EXISTS (
    SELECT *
    FROM sysobjects
    WHERE id = OBJECT_ID(N'{databaseOwner}[{objectQualifier}lm_ProductMappings_Get]')
      AND type = 'P'
)
    DROP PROCEDURE {databaseOwner}[{objectQualifier}lm_ProductMappings_Get]
GO

CREATE PROCEDURE {databaseOwner}[{objectQualifier}lm_ProductMappings_Get]
    @ModuleId INT,
    @LanguageId INT,
    @QuestionLevelId INT,
    @SkillTypeId INT,
    @Take INT
AS
BEGIN
    SET NOCOUNT ON;

    SELECT TOP (@Take)
        [ProductMappingId],
        [ModuleId],
        [HotcakesProductSKU],
        [LanguageId],
        [QuestionLevelId],
        [SkillTypeId],
        [ProductKind],
        [Priority],
        [IsActive]
    FROM {databaseOwner}[{objectQualifier}lm_product_mappings]
    WHERE ([ModuleId] = @ModuleId OR [ModuleId] = 0)
      AND [LanguageId] = @LanguageId
      AND ([QuestionLevelId] = @QuestionLevelId OR [QuestionLevelId] IS NULL)
      AND [SkillTypeId] = @SkillTypeId
      AND [IsActive] = 1
    ORDER BY
        CASE WHEN [ModuleId] = @ModuleId THEN 0 ELSE 1 END,
        CASE WHEN [QuestionLevelId] = @QuestionLevelId THEN 0 ELSE 1 END,
        [Priority],
        NEWID();
END
GO


