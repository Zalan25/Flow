@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Dnn.Flow.QuizLearn.Models.ResultViewModel>

@{
    var percent = Model.TotalScore * 100 / 50;

    var levelClass = "level-a1";
    if (Model.FinalLevelName == "A2") { levelClass = "level-a2"; }
    else if (Model.FinalLevelName == "B1") { levelClass = "level-b1"; }
    else if (Model.FinalLevelName == "B2") { levelClass = "level-b2"; }
    else if (Model.FinalLevelName.Contains("C1")) { levelClass = "level-c1"; }
}

<div class="quizlearn-wrapper">
    <div class="quizlearn-card">

        <div class="quizlearn-step-indicator">
            <span class="done">1</span>
            <span class="done">2</span>
            <span class="active">3</span>
        </div>

        <h2 class="quizlearn-title">Szintfelmérő eredmény</h2>

        <div class="quizlearn-score-circle @levelClass">
            <div class="quizlearn-score-value">@Model.TotalScore</div>
            <div class="quizlearn-score-max">/ 50</div>
        </div>

        <div class="quizlearn-score-label">
            Összpontszám
        </div>

        <div class="quizlearn-level">
            <span>Javasolt szint:</span>
            <span class="quizlearn-level-badge @levelClass">@Model.FinalLevelName</span>
        </div>

        <div class="quizlearn-feedback @levelClass">
            @if (Model.FinalLevelName == "A1")
            {
                <span>Az alapok megerősítése javasolt. Érdemes A1-es tananyaggal kezdeni.</span>
            }
            else if (Model.FinalLevelName == "A2")
            {
                <span>Az alapok már megvannak, de az A2-es szint stabilizálása ajánlott.</span>
            }
            else if (Model.FinalLevelName == "B1")
            {
                <span>Jó alapokkal rendelkezel. A következő lépés a magabiztosabb önálló nyelvhasználat.</span>
            }
            else if (Model.FinalLevelName == "B2")
            {
                <span>Erős középszintű tudás látszik. Érdemes B2-es vagy C1-re felkészítő anyagokkal továbbhaladni.</span>
            }
            else
            {
                <span>Magas szintű tudás látszik. C1-közeli fejlesztő és szinten tartó anyagok ajánlottak.</span>
            }
        </div>

        <div class="quizlearn-details">
            <h3>Részletes eredmény</h3>

            <div class="quizlearn-row">
                <span>A1 helyes válaszok</span>
                <strong>@Model.A1Correct</strong>
            </div>
            <div class="quizlearn-row">
                <span>A2 helyes válaszok</span>
                <strong>@Model.A2Correct</strong>
            </div>
            <div class="quizlearn-row">
                <span>B1 helyes válaszok</span>
                <strong>@Model.B1Correct</strong>
            </div>
            <div class="quizlearn-row">
                <span>B2 helyes válaszok</span>
                <strong>@Model.B2Correct</strong>
            </div>
            <div class="quizlearn-row">
                <span>C1 helyes válaszok</span>
                <strong>@Model.C1Correct</strong>
            </div>
        </div>

        <div class="quizlearn-actions">
            <a href="@Url.Action("Index", "Item")" class="quizlearn-button">
                Új teszt indítása
            </a>
        </div>

    </div>
</div>

<style>
    .quizlearn-wrapper {
        background: #f3f6fb;
        padding: 32px 16px;
        display: flex;
        justify-content: center;
    }

    .quizlearn-card {
        width: 100%;
        max-width: 720px;
        background: #ffffff;
        border-radius: 10px;
        padding: 40px 48px;
        box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.18);
        text-align: center;
    }

    .quizlearn-step-indicator {
        display: flex;
        justify-content: center;
        gap: 18px;
        margin-bottom: 26px;
    }

        .quizlearn-step-indicator span {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #d8dee8;
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            font-weight: 700;
        }

        .quizlearn-step-indicator .done {
            background: #142943;
        }

        .quizlearn-step-indicator .active {
            background: #142943;
            box-shadow: 0 0 0 5px rgba(20, 41, 67, 0.22);
        }

    .quizlearn-title {
        font-size: 34px;
        color: #142943;
        margin: 0 0 24px 0;
        font-weight: 700;
    }

    .quizlearn-score-circle {
        width: 132px;
        height: 132px;
        border-radius: 50%;
        margin: 0 auto 8px auto;
        border: 10px solid #142943;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        background: #ffffff;
    }

    .quizlearn-score-value {
        font-size: 42px;
        font-weight: 800;
        line-height: 1;
    }

    .quizlearn-score-max {
        font-size: 22px;
        font-weight: 700;
        opacity: 0.75;
        padding-top: 12px;
    }

    .quizlearn-score-label {
        font-size: 16px;
        color: #5b6b7f;
        margin-bottom: 24px;
    }

    .quizlearn-level {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        font-size: 20px;
        color: #142943;
        margin-bottom: 18px;
    }

    .quizlearn-level-badge {
        display: inline-block;
        min-width: 52px;
        padding: 7px 14px;
        color: #ffffff;
        border-radius: 6px;
        font-weight: 800;
    }

    .quizlearn-feedback {
        max-width: 520px;
        margin: 0 auto 30px auto;
        border-radius: 8px;
        padding: 14px 18px;
        font-size: 16px;
        line-height: 1.45;
        text-align: left;
        border-left: 5px solid #142943;
        background: #f4f7fb;
        color: #142943;
    }

    .quizlearn-details {
        text-align: left;
        max-width: 460px;
        margin: 0 auto 30px auto;
    }

        .quizlearn-details h3 {
            margin: 0 0 14px 0;
            color: #142943;
            font-size: 26px;
            text-align: center;
        }

    .quizlearn-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5eaf1;
        padding: 9px 0;
        font-size: 17px;
    }

        .quizlearn-row strong {
            color: #142943;
            font-size: 18px;
        }

    .quizlearn-actions {
        margin-top: 8px;
    }

    .quizlearn-button {
        background: #142943;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 12px 22px;
        font-size: 18px;
        text-decoration: none;
        display: inline-block;
    }

        .quizlearn-button:hover {
            background: #1d3b60;
            color: #ffffff;
            text-decoration: none;
        }

    .level-a1.quizlearn-score-circle,
    .level-a1.quizlearn-level-badge {
        border-color: #9b2c2c;
        background-color: #9b2c2c;
        color: #ffffff;
    }

    .level-a2.quizlearn-score-circle,
    .level-a2.quizlearn-level-badge {
        border-color: #b7791f;
        background-color: #b7791f;
        color: #ffffff;
    }

    .level-b1.quizlearn-score-circle,
    .level-b1.quizlearn-level-badge {
        border-color: #2f855a;
        background-color: #2f855a;
        color: #ffffff;
    }

    .level-b2.quizlearn-score-circle,
    .level-b2.quizlearn-level-badge {
        border-color: #2b6cb0;
        background-color: #2b6cb0;
        color: #ffffff;
    }

    .level-c1.quizlearn-score-circle,
    .level-c1.quizlearn-level-badge {
        border-color: #553c9a;
        background-color: #553c9a;
        color: #ffffff;
    }

    .quizlearn-score-circle .quizlearn-score-value,
    .quizlearn-score-circle .quizlearn-score-max {
        color: #ffffff;
    }

    .quizlearn-feedback.level-a1 {
        border-left-color: #9b2c2c;
    }

    .quizlearn-feedback.level-a2 {
        border-left-color: #b7791f;
    }

    .quizlearn-feedback.level-b1 {
        border-left-color: #2f855a;
    }

    .quizlearn-feedback.level-b2 {
        border-left-color: #2b6cb0;
    }

    .quizlearn-feedback.level-c1 {
        border-left-color: #553c9a;
    }

    @@media (max-width: 640px) {
        .quizlearn-card {
            padding: 28px 20px;
        }

        .quizlearn-title {
            font-size: 27px;
        }

        .quizlearn-score-circle {
            width: 112px;
            height: 112px;
        }

        .quizlearn-score-value {
            font-size: 34px;
        }

        .quizlearn-score-max {
            font-size: 18px;
        }

        .quizlearn-level {
            flex-direction: column;
            gap: 8px;
        }
    }
</style>