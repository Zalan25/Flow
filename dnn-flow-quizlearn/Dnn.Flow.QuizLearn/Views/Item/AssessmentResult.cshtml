@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Dnn.Flow.QuizLearn.Models.ResultViewModel>
<link rel="stylesheet" href="/DesktopModules/MVC/Dnn.Flow.QuizLearn/css/quizlearn.css?v=13" />
@{
    var percent = Model.TotalScore * 100 / 50;

    var levelClass = "level-a1";
    if (Model.FinalLevelName == "A2") { levelClass = "level-a2"; }
    else if (Model.FinalLevelName == "B1") { levelClass = "level-b1"; }
    else if (Model.FinalLevelName == "B2") { levelClass = "level-b2"; }
    else if (Model.FinalLevelName.Contains("C1")) { levelClass = "level-c1"; }

    var circleStyle = "background: conic-gradient(var(--level-color) " + percent + "%, #e5eaf1 " + percent + "%);";
}

<div class="quizlearn-wrapper">
    <div class="quizlearn-card">

        <div class="quizlearn-step-indicator">
            <span class="done">1</span>
            <span class="done">2</span>
            <span class="active">3</span>
        </div>

        <h2 class="quizlearn-title">Szintfelmérő eredmény</h2>

        <div class="quizlearn-score-circle @levelClass" style="@circleStyle">
            <div class="quizlearn-score-inner">
                <div class="quizlearn-score-value">@Model.TotalScore</div>
                <div class="quizlearn-score-max">/ 50</div>
            </div>
        </div>

        <div class="quizlearn-score-label">
            @percent% teljesítmény
        </div>

        <div class="quizlearn-level">
            <span>Javasolt szint:</span>
            <span class="quizlearn-level-badge @levelClass">@Model.FinalLevelName</span>
        </div>

        <div class="quizlearn-feedback @levelClass">
            @if (Model.FinalLevelName == "A1")
            {
                <span>Az alapok megerősítése javasolt. Érdemes A1-es tananyaggal kezdeni.</span>
            }
            else if (Model.FinalLevelName == "A2")
            {
                <span>Az alapok már megvannak, de az A2-es szint stabilizálása ajánlott.</span>
            }
            else if (Model.FinalLevelName == "B1")
            {
                <span>Jó alapokkal rendelkezel. A következő lépés a magabiztosabb önálló nyelvhasználat.</span>
            }
            else if (Model.FinalLevelName == "B2")
            {
                <span>Erős középszintű tudás látszik. Érdemes B2-es vagy C1-re felkészítő anyagokkal továbbhaladni.</span>
            }
            else
            {
                <span>Magas szintű tudás látszik. C1-közeli fejlesztő és szinten tartó anyagok ajánlottak.</span>
            }
        </div>

        <div class="quizlearn-details">
            <h3>Részletes eredmény</h3>

            <div class="quizlearn-row">
                <span>A1 helyes válaszok</span>
                <strong>@Model.A1Correct</strong>
            </div>
            <div class="quizlearn-row">
                <span>A2 helyes válaszok</span>
                <strong>@Model.A2Correct</strong>
            </div>
            <div class="quizlearn-row">
                <span>B1 helyes válaszok</span>
                <strong>@Model.B1Correct</strong>
            </div>
            <div class="quizlearn-row">
                <span>B2 helyes válaszok</span>
                <strong>@Model.B2Correct</strong>
            </div>
            <div class="quizlearn-row">
                <span>C1 helyes válaszok</span>
                <strong>@Model.C1Correct</strong>
            </div>
        </div>

        <div class="quizlearn-actions">
            <a href="@Url.Action("Index", "Item")" class="quizlearn-button">
                Új teszt indítása
            </a>
        </div>

    </div>
</div>
