@Model Dnn.Flow.QuizLearn.Models.AssessmentStartViewModel
@using System.Web.Mvc

<h2>QuizLearn – Pilot</h2>
<p>Válaszd ki a beállításokat.</p>

<form method="post">
    <input type="hidden" name="ModuleId" value="@Model.ModuleId" />

    <div>
        <label>Assessment mód</label>
        <input type="text" name="AssessmentModeId" value="@Model.AssessmentModeId" />
    </div>

    <div>
        <label>Nyelv</label>
        <select name="LanguageId">
            <option value="">-- válassz nyelvet --</option>
            @foreach (var language in Model.Languages)
            {
            <option value="@language.LanguageId">@language.Name</option>
            }
        </select>
    </div>

    <div>
        <label>Másodlagos nyelv</label>
        <select name="SecondaryLanguageId">
            <option value="">-- nincs --</option>
            @foreach (var language in Model.Languages)
            {
            <option value="@language.LanguageId">@language.Name</option>
            }
        </select>
    </div>

    <div>
        <label>Szint</label>
        <select name="SelectedLevelId">
            <option value="">-- válassz szintet --</option>
            @foreach (var level in Model.Levels)
            {
            <option value="@level.QuestionLevelId">@level.LevelName</option>
            }
        </select>
    </div>

    <div>
        <label>Tempó</label>
        <select name="PaceTypeId">
            <option value="">-- válassz tempót --</option>
            @foreach (var pace in Model.PaceTypes)
            {
            <option value="@pace.PaceTypeId">@pace.PaceName</option>
            }
        </select>
    </div>

    <div>
        <label>Készségek</label>
        @foreach (var skill in Model.Skills)
        {
        <div>
            <input type="checkbox" name="SelectedSkillTypeIds" value="@skill.SkillTypeId" />
            <span>@skill.SkillName</span>
        </div>
        }
    </div>

    <div style="margin-top:15px;">
        <button type="submit">Ajánlás indítása</button>
    </div>
</form>