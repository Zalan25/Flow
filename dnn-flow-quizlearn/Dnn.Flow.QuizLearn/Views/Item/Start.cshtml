@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Dnn.Flow.QuizLearn.Models.AssessmentStartViewModel>
<link rel="stylesheet" href="/DesktopModules/YourRfProjects/dnn-flow-quizlearn/Dnn.Flow.QuizLearn/css/quizlearn.css?v=12" />

<div class="quizlearn-wrapper">
    <div class="quizlearn-card quizlearn-recommendation-card">


        <form method="post" class="quizlearn-form" id="recommendationForm">
            @Html.AntiForgeryToken()

            <input type="hidden" name="AssessmentAction" value="StartRecommendation" />
            <input type="hidden" name="AssessmentModeId" value="@Model.AssessmentModeId" />
            <input type="hidden" id="NeedLevelTest" name="NeedLevelTest" value="false" />
            <input type="hidden" id="ServerValidationStep" value="@ViewBag.ServerValidationStep" />

            <div class="quizlearn-step-nav">
                <button type="button" class="quizlearn-step-circle active" data-go-step="1">1</button>
                <span></span>
                <button type="button" class="quizlearn-step-circle" data-go-step="2">2</button>
                <span></span>
                <button type="button" class="quizlearn-step-circle" data-go-step="3">3</button>
                <span></span>
                <button type="button" class="quizlearn-step-circle" data-go-step="4">4</button>
            </div>

            <!-- STEP 1 -->
            <section class="quizlearn-start-step active" data-step="1">
                <h2 class="quizlearn-title">Milyen nyelvet szeretnél tanulni?</h2>
                <div class="quizlearn-step-error">Kérlek válassz egy opciót!</div>

                <div class="quizlearn-language-grid">
                    @foreach (var language in Model.Languages)
                    {
                        <label class="quizlearn-start-option quizlearn-language-option">
                            <input type="radio" name="LanguageId" value="@language.LanguageId" />

                            <span class="quizlearn-option-image quizlearn-language-flag">
                                <img src="@GetLanguageFlagPath(language.Name)" alt="@language.Name" />
                            </span>

                            <span class="quizlearn-option-text">@language.Name</span>
                        </label>
                    }
                </div>

                <button type="button" class="quizlearn-button quizlearn-next-button">Következő</button>
            </section>

            <!-- STEP 2 -->
            <section class="quizlearn-start-step" data-step="2">
                <h2 class="quizlearn-title">Miben szeretnél fejlődni?</h2>

                <div class="quizlearn-step-error">Kérlek válassz egy opciót!</div>
                <div class="quizlearn-skill-grid">
                    @foreach (var skill in Model.Skills)
                    {
                        <label class="quizlearn-start-option quizlearn-skill-option">
                            <input type="checkbox" name="SelectedSkillTypeIds" value="@skill.SkillTypeId" />
                            <span>@GetSkillDisplayName(skill.SkillName)</span>
                            <span class="quizlearn-option-icon">@GetSkillIcon(skill.SkillName)</span>
                        </label>
                    }
                </div>

                <button type="button" class="quizlearn-button quizlearn-next-button">Következő</button>
            </section>

            <!-- STEP 3 -->
            <section class="quizlearn-start-step" data-step="3">
                <h2 class="quizlearn-title">Hol tartasz most?</h2>

                <div class="quizlearn-step-error">Kérlek válassz egy opciót!</div>
                <div class="quizlearn-level-list">
                    @foreach (var level in Model.Levels)
                    {
                        <label class="quizlearn-start-option quizlearn-level-option">
                            <input type="radio" name="SelectedLevelId" value="@level.QuestionLevelId" />
                            <span class="quizlearn-option-icon">@GetLevelIcon(level.LevelName)</span>
                            <span>@GetLevelDisplayName(level.LevelName)</span>
                        </label>
                    }

                    <label class="quizlearn-start-option quizlearn-level-option">
                        <input type="radio" name="LevelChoice" value="NeedLevelTest" />
                        <span class="quizlearn-option-icon">?</span>
                        <span>Nem tudom - Szintfelmérő kitöltése</span>
                    </label>
                </div>

                <button type="button" class="quizlearn-button quizlearn-next-button">Következő</button>
            </section>

            <!-- STEP 4 -->
            <section class="quizlearn-start-step" data-step="4">
                <h2 class="quizlearn-title">Milyen tempóban szeretnél haladni?</h2>

                <div class="quizlearn-step-error">Kérlek válassz egy opciót!</div>

                <div class="quizlearn-pace-list">
                    @foreach (var pace in Model.PaceTypes)
                    {
                        <label class="quizlearn-start-option quizlearn-pace-option">
                            <input type="radio" name="PaceTypeId" value="@pace.PaceTypeId" />

                            <span class="quizlearn-option-icon">
                                @GetPaceIcon(pace.PaceName)
                            </span>

                            <span class="quizlearn-option-text">
                                @pace.PaceName
                            </span>
                        </label>
                    }
                </div>

                <button type="submit" class="quizlearn-button">
                    Ajánlás megtekintése
                </button>
            </section>
        </form>
    </div>
</div>

@functions {
    private string GetLanguageFlagPath(string languageName)
    {
        var name = languageName.ToLower();

        if (name.Contains("angol")) return "/Portals/0/QuizLearn/flags/en.svg";
        if (name.Contains("görög")) return "/Portals/0/QuizLearn/flags/gr.svg";
        if (name.Contains("kínai")) return "/Portals/0/QuizLearn/flags/cn.svg";
        if (name.Contains("orosz")) return "/Portals/0/QuizLearn/flags/ru.svg";
        if (name.Contains("japán")) return "/Portals/0/QuizLearn/flags/jp.svg";
        if (name.Contains("török")) return "/Portals/0/QuizLearn/flags/tr.svg";
        if (name.Contains("horvát")) return "/Portals/0/QuizLearn/flags/hr.svg";
        if (name.Contains("portugál")) return "/Portals/0/QuizLearn/flags/pt.svg";

        return "/Portals/0/QuizLearn/flags/default.svg";
    }
    private string GetSkillDisplayName(string skillName)
    {
        switch (skillName)
        {
            case "Vocabulary": return "Szókincs";
            case "Reading": return "Olvasás";
            case "Listening": return "Hallás utáni értés";
            case "Practice": return "Gyakorlás";
            case "SelfStudy": return "Komplett tanulás";
            default: return skillName;
        }
    }

    private string GetSkillIcon(string skillName)
    {
        switch (skillName)
        {
            case "Vocabulary": return "💬";
            case "Reading": return "📖";
            case "Listening": return "🎧";
            case "Practice": return "📈";
            case "SelfStudy": return "🎯";
            default: return "✓";
        }
    }

    private string GetLevelDisplayName(string levelName)
    {
        switch (levelName)
        {
            case "A1": return "Most kezdtem (A1)";
            case "A2": return "Már tanulom, de bizonytalan vagyok (A2)";
            case "B1": return "Elboldogulok (B1)";
            case "B2": return "Magabiztos vagyok (B2)";
            case "C1": return "Szinte profi vagyok (C1)";
            default: return levelName;
        }
    }

    private string GetLevelIcon(string levelName)
    {
        switch (levelName)
        {
            case "A1": return "🚀";
            case "A2": return "📖";
            case "B1": return "💡";
            case "B2": return "📈";
            case "C1": return "🎯";
            default: return "✓";
        }
    }

    private string GetPaceIcon(string paceName)
    {
        if (paceName.ToLower().Contains("nyugodt")) return "🕒";
        if (paceName.ToLower().Contains("gyors")) return "⚡";
        return "🎯";
    }
}

<script>
    function validateStep(step) {
        var stepElement = document.querySelector('.quizlearn-start-step[data-step="' + step + '"]');

        if (!stepElement) return false;

        var checkboxes = stepElement.querySelectorAll('input[type="checkbox"]');
        if (checkboxes.length > 0) {
            return Array.from(checkboxes).some(function (c) {
                return c.checked;
            });
        }

        var radios = stepElement.querySelectorAll('input[type="radio"]');
        if (radios.length > 0) {
            return Array.from(radios).some(function (r) {
                return r.checked;
            });
        }

        return true;
    }

    function showStepError(step) {
        var stepElement = document.querySelector('.quizlearn-start-step[data-step="' + step + '"]');
        if (!stepElement) return;

        stepElement.querySelectorAll(".quizlearn-start-option").forEach(function (el) {
            el.classList.add("quizlearn-invalid");
        });

        var errorElement = stepElement.querySelector(".quizlearn-step-error");
        if (errorElement) {
            errorElement.classList.add("active");
            errorElement.style.display = "block";
        }
    }
    (function () {
        var currentStep = 1;
        var maxStep = 4;

        var steps = document.querySelectorAll(".quizlearn-start-step");
        var circles = document.querySelectorAll(".quizlearn-step-circle");
        var nextButtons = document.querySelectorAll(".quizlearn-next-button");
        var needLevelTestInput = document.getElementById("NeedLevelTest");
        var submitButton = document.getElementById("recommendationSubmitButton");
        var recommendationForm = document.getElementById("recommendationForm");

        

        function clearStepError(stepElement) {
            if (!stepElement) return;

            stepElement.querySelectorAll(".quizlearn-start-option").forEach(function (el) {
                el.classList.remove("quizlearn-invalid");
            });

            var errorElement = stepElement.querySelector(".quizlearn-step-error");
            if (errorElement) {
                errorElement.classList.remove("active");
                errorElement.style.display = "none";
            }
        }

        function showStep(step) {
            currentStep = step;
            sessionStorage.setItem("quizlearn-step", step);

            steps.forEach(function (el) {
                el.classList.remove("active");
            });

            var targetStep = document.querySelector('.quizlearn-start-step[data-step="' + step + '"]');
            if (targetStep) {
                targetStep.classList.add("active");
            }

            circles.forEach(function (circle) {
                var circleStep = parseInt(circle.getAttribute("data-go-step"), 10);

                circle.classList.remove("active");
                circle.classList.remove("done");

                if (circleStep < currentStep) {
                    circle.classList.add("done");
                }

                if (circleStep === currentStep) {
                    circle.classList.add("active");
                }
            });
        }

        function updateSelectedStates(input) {
            var parentStep = input.closest(".quizlearn-start-step");
            clearStepError(parentStep);

            if (input.type === "radio") {
                var sameNameInputs = document.querySelectorAll('input[name="' + input.name + '"]');

                sameNameInputs.forEach(function (radio) {
                    var parent = radio.closest(".quizlearn-start-option");
                    if (parent) parent.classList.remove("selected");
                });
            }

            var parent = input.closest(".quizlearn-start-option");
            if (parent) {
                parent.classList.toggle("selected", input.checked);
            }

            if (input.name === "SelectedLevelId") {
                needLevelTestInput.value = "false";

                var levelTestInput = document.querySelector('input[name="LevelChoice"]');
                if (levelTestInput) {
                    levelTestInput.checked = false;
                    var levelTestParent = levelTestInput.closest(".quizlearn-start-option");
                    if (levelTestParent) levelTestParent.classList.remove("selected");
                }
            }

            if (input.name === "LevelChoice" && input.value === "NeedLevelTest") {
                needLevelTestInput.value = "true";

                var selectedLevels = document.querySelectorAll('input[name="SelectedLevelId"]');
                selectedLevels.forEach(function (levelInput) {
                    levelInput.checked = false;
                    var levelParent = levelInput.closest(".quizlearn-start-option");
                    if (levelParent) levelParent.classList.remove("selected");
                });
            }
        }

        document.querySelectorAll(".quizlearn-start-option input").forEach(function (input) {
            input.addEventListener("change", function () {
                updateSelectedStates(input);
            });
        });

        nextButtons.forEach(function (btn) {
            btn.addEventListener("click", function () {
                if (!validateStep(currentStep)) {
                    showStepError(currentStep);
                    return;
                }

                if (currentStep < maxStep) {
                    showStep(currentStep + 1);
                }
            });
        });

        circles.forEach(function (circle) {
            circle.addEventListener("click", function () {
                var targetStep = parseInt(circle.getAttribute("data-go-step"), 10);

                if (targetStep < 1 || targetStep > maxStep) {
                    return;
                }

                if (targetStep <= currentStep) {
                    showStep(targetStep);
                    return;
                }

                if (!validateStep(currentStep)) {
                    showStepError(currentStep);
                    return;
                }

                if (targetStep === currentStep + 1) {
                    showStep(targetStep);
                }
            });
        });


        var recommendationForm = document.getElementById("recommendationForm");

        if (recommendationForm) {
            recommendationForm.addEventListener("submit", function (e) {
                e.preventDefault();

                if (!validateStep(4)) {
                    showStep(4);
                    showStepError(4);
                    return false;
                }

                sessionStorage.removeItem("quizlearn-step");

                HTMLFormElement.prototype.submit.call(recommendationForm);
            });
        }

        var serverValidationStepInput = document.getElementById("ServerValidationStep");
        var serverValidationStep = serverValidationStepInput
            ? parseInt(serverValidationStepInput.value, 10)
            : 0;

        if (serverValidationStep > 0) {
            showStep(serverValidationStep);
            showStepError(serverValidationStep);
        } else if (!sessionStorage.getItem("quizlearn-step")) {
            showStep(1);
        } else {
            showStep(parseInt(sessionStorage.getItem("quizlearn-step"), 10));
        }
    })();
</script>