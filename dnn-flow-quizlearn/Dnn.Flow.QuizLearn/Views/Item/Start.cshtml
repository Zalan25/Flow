@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Dnn.Flow.QuizLearn.Models.AssessmentStartViewModel>
<link rel="stylesheet" href="/DesktopModules/YourRfProjects/dnn-flow-quizlearn/Dnn.Flow.QuizLearn/css/quizlearn.css" />

<div class="ql-rec-wrapper">
    <div class="ql-rec-card">

        <form method="post" id="recommendationForm">
            @Html.AntiForgeryToken()

            <input type="hidden" name="AssessmentAction" value="StartRecommendation" />
            <input type="hidden" name="AssessmentModeId" value="@Model.AssessmentModeId" />
            <input type="hidden" name="NeedLevelTest" value="false" />

            <!-- STEP 1 -->
            <div class="ql-step active" data-step="1">
                <div class="ql-steps">
                    <span class="active">1</span><span>2</span><span>3</span><span>4</span>
                </div>

                <h2>Milyen nyelvet szeretnél tanulni?</h2>

                <div class="ql-language-grid">
                    @foreach (var language in Model.Languages)
                    {
                        <label class="ql-choice ql-language-choice">
                            <input type="radio" name="LanguageId" value="@language.LanguageId" />
                            <span class="ql-icon-placeholder"></span>
                            <span>@language.Name</span>
                        </label>
                    }
                </div>

                <button type="button" class="ql-btn next-btn">Következő</button>
            </div>

            <!-- STEP 2 -->
            <div class="ql-step" data-step="2">
                <div class="ql-steps">
                    <span class="done">1</span><span class="active">2</span><span>3</span><span>4</span>
                </div>

                <h2>Miben szeretnél fejlődni?</h2>

                <div class="ql-skill-grid">
                    @foreach (var skill in Model.Skills)
                    {
                        <label class="ql-choice ql-skill-choice">
                            <input type="checkbox" name="SelectedSkillTypeIds" value="@skill.SkillTypeId" />
                            <span>@GetSkillDisplayName(skill.SkillName)</span>
                            <span class="ql-icon-placeholder small"></span>
                        </label>
                    }
                </div>

                <button type="button" class="ql-btn next-btn">Következő</button>
            </div>

            <!-- STEP 3 -->
            <div class="ql-step" data-step="3">
                <div class="ql-steps">
                    <span class="done">1</span><span class="done">2</span><span class="active">3</span><span>4</span>
                </div>

                <h2>Hol tartasz most?</h2>

                <div class="ql-level-list">
                    @foreach (var level in Model.Levels)
                    {
                        <label class="ql-choice ql-level-choice">
                            <input type="radio" name="SelectedLevelId" value="@level.QuestionLevelId" />
                            <span class="ql-icon-placeholder tiny"></span>
                            <span>@GetLevelDisplayName(level.LevelName)</span>
                        </label>
                    }

                    <label class="ql-choice ql-level-choice">
                        <input type="radio" name="NeedLevelTest" value="true" />
                        <span class="ql-icon-placeholder tiny"></span>
                        <span>Nem tudom - Szintfelmérő kitöltése</span>
                    </label>
                </div>

                <button type="button" class="ql-btn next-btn">Következő</button>
            </div>

            <!-- STEP 4 -->
            <div class="ql-step" data-step="4">
                <div class="ql-steps">
                    <span class="done">1</span><span class="done">2</span><span class="done">3</span><span class="active">4</span>
                </div>

                <h2>Milyen tempóban szeretnél haladni?</h2>

                <div class="ql-pace-list">
                    @foreach (var pace in Model.PaceTypes)
                    {
                        <label class="ql-choice ql-pace-choice">
                            <input type="radio" name="PaceTypeId" value="@pace.PaceTypeId" />
                            <span class="ql-icon-placeholder tiny"></span>
                            <span>@pace.PaceName</span>
                        </label>
                    }
                </div>

                <button type="submit" class="ql-btn">Ajánlás megtekintése</button>
            </div>
        </form>
    </div>
</div>

@functions {
    private string GetSkillDisplayName(string skillName)
    {
        switch (skillName)
        {
            case "Vocabulary": return "Szókincs";
            case "Reading": return "Olvasás";
            case "Listening": return "Hallás utáni értés";
            case "Practice": return "Gyakorlás";
            case "SelfStudy": return "Komplett tanulás";
            default: return skillName;
        }
    }

    private string GetLevelDisplayName(string levelName)
    {
        switch (levelName)
        {
            case "A1": return "Most kezdtem (A1)";
            case "A2": return "Már tanulom, de bizonytalan vagyok (A2)";
            case "B1": return "Elboldogulok (B1)";
            case "B2": return "Magabiztos vagyok (B2)";
            case "C1": return "Szinte profi vagyok (C1)";
            default: return levelName;
        }
    }
}

<script>
    (function () {
        var currentStep = 1;
        var steps = document.querySelectorAll(".ql-step");
        var nextButtons = document.querySelectorAll(".next-btn");

        function showStep(step) {
            steps.forEach(function (el) {
                el.classList.remove("active");
            });

            var target = document.querySelector('.ql-step[data-step="' + step + '"]');
            if (target) {
                target.classList.add("active");
            }
        }

        nextButtons.forEach(function (btn) {
            btn.addEventListener("click", function () {
                if (currentStep < 4) {
                    currentStep++;
                    showStep(currentStep);
                }
            });
        });
    })();
</script>