@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Dnn.Flow.QuizLearn.Models.QuestionViewModel>

<div class="quizlearn-wrapper">
    <div class="quizlearn-card">

        <div class="quizlearn-progress-text">
            Kérdés @Model.QuestionNumber / @Model.TotalQuestions
        </div>

        <div class="quizlearn-progress">
            <div class="quizlearn-progress-bar" style="width:@((Model.QuestionNumber * 100) / Model.TotalQuestions)%"></div>
        </div>

        <h2 class="quizlearn-title">
            @Model.QuestionText
        </h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="quizlearn-error">
                @foreach (var state in ViewData.ModelState.Values)
                {
                    foreach (var error in state.Errors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                }
            </div>
        }

        <form method="post" class="quizlearn-form">
            @Html.AntiForgeryToken()

            <input type="hidden" name="AssessmentAction" value="AnswerQuestion" />
            <input type="hidden" name="SessionId" value="@Model.SessionId" />
            <input type="hidden" name="QuestionId" value="@Model.QuestionId" />
            <input type="hidden" name="QuestionNumber" value="@Model.QuestionNumber" />
            <input type="hidden" name="QuestionTypeId" value="@Model.QuestionTypeId" />

            <div class="quizlearn-options">

                @if (Model.RequiresTextAnswer)
                {
                    <textarea id="TextAnswer"
                              name="TextAnswer"
                              class="quizlearn-textarea"
                              rows="5"
                              placeholder="Írd ide a válaszodat..."></textarea>
                }
                else if (Model.AllowsMultipleAnswers)
                {
                    foreach (var answer in Model.Answers)
                    {
                        <label class="quizlearn-option">
                            <input type="checkbox"
                                   name="SelectedAnswerIds"
                                   value="@answer.AnswerId" />
                            <span>@answer.AnswerText</span>
                        </label>
                    }
                }
                else
                {
                    foreach (var answer in Model.Answers)
                    {
                        <label class="quizlearn-option">
                            <input type="radio"
                                   name="AnswerId"
                                   value="@answer.AnswerId" />
                            <span>@answer.AnswerText</span>
                        </label>
                    }
                }

            </div>

            <button type="submit" class="quizlearn-button">
                Következő
            </button>
        </form>
    </div>
</div>

<style>
    .quizlearn-wrapper {
        background: #f3f6fb;
        padding: 32px 16px;
        display: flex;
        justify-content: center;
    }

    .quizlearn-card {
        width: 100%;
        max-width: 720px;
        background: #ffffff;
        border-radius: 10px;
        padding: 40px 48px;
        box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.18);
        text-align: center;
    }

    .quizlearn-progress-text {
        font-size: 16px;
        font-weight: 600;
        color: #142943;
        margin-bottom: 10px;
    }

    .quizlearn-progress {
        height: 10px;
        background: #d8dee8;
        border-radius: 999px;
        overflow: hidden;
        margin-bottom: 32px;
    }

    .quizlearn-progress-bar {
        height: 100%;
        background: #142943;
        border-radius: 999px;
        transition: width 0.3s ease;
    }

    .quizlearn-title {
        font-size: 32px;
        line-height: 1.25;
        color: #142943;
        margin-bottom: 28px;
        font-weight: 700;
    }

    .quizlearn-form {
        margin: 0;
    }

    .quizlearn-options {
        max-width: 520px;
        margin: 0 auto 24px auto;
    }

    .quizlearn-option {
        display: flex;
        align-items: center;
        gap: 14px;
        border: 2px solid #233b5b;
        border-radius: 7px;
        padding: 10px 18px;
        margin-bottom: 10px;
        font-size: 20px;
        line-height: 1.3;
        color: #111827;
        cursor: pointer;
        background: #ffffff;
        transition: all 0.15s ease;
        text-align: left;
    }

    .quizlearn-option:hover {
        background: #edf3fb;
        border-color: #142943;
    }

    .quizlearn-option input {
        transform: scale(1.2);
        accent-color: #142943;
    }

    .quizlearn-option span {
        flex: 1;
    }

    .quizlearn-textarea {
        width: 100%;
        border: 2px solid #233b5b;
        border-radius: 7px;
        padding: 14px 16px;
        font-size: 18px;
        resize: vertical;
        box-sizing: border-box;
    }

    .quizlearn-textarea:focus {
        outline: none;
        border-color: #142943;
        box-shadow: 0 0 0 3px rgba(20, 41, 67, 0.15);
    }

    .quizlearn-button {
        background: #142943;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 12px 22px;
        font-size: 20px;
        cursor: pointer;
        transition: background 0.15s ease;
    }

    .quizlearn-button:hover {
        background: #1d3b60;
    }

    .quizlearn-error {
        max-width: 520px;
        margin: 0 auto 18px auto;
        background: #ffe8e8;
        color: #8a1f1f;
        border: 1px solid #e0a5a5;
        border-radius: 6px;
        padding: 10px 14px;
        text-align: left;
    }

    @@media (max-width: 640px) {
        .quizlearn-card {
            padding: 28px 20px;
        }

        .quizlearn-title {
            font-size: 25px;
        }

        .quizlearn-option {
            font-size: 17px;
        }
    }
</style>