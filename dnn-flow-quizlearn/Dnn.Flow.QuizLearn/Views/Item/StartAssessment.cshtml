<form method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="AssessmentAction" value="StartLevelTest" />

    @if (Model.HasExistingSession)
    {
    <input type="hidden" name="SessionId" value="@Model.SessionId" />
    <input type="hidden" name="LanguageId" value="@Model.LanguageId" />

    <p>A szintfelmérő a kiválasztott nyelv alapján indul.</p>
    }
    else
    {
    <label>Válassz nyelvet:</label>

    <select name="LanguageId">
        <option value="">-- Válassz nyelvet --</option>

        @foreach (var lang in Model.Languages)
            {
        <option value="@lang.LanguageId">@lang.Name</option>
            }
    </select>
    }

    <button type="submit">Indítás</button>
</form>