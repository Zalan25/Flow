@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Dnn.Flow.QuizLearn.Models.AssessmentStartViewModel>

<div class="quizlearn-wrapper">
    <div class="quizlearn-card">

        <div class="quizlearn-step-indicator">
            <span class="active">1</span>
            <span>2</span>
            <span>3</span>
        </div>

        <h2 class="quizlearn-title">Szintfelmérő indítása</h2>

        <p class="quizlearn-description">
            A szintfelmérő segít meghatározni, hogy jelenleg milyen nyelvi szinten vagy.
        </p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="quizlearn-error">
                @foreach (var state in ViewData.ModelState.Values)
                {
                    foreach (var error in state.Errors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                }
            </div>
        }

        <form method="post" class="quizlearn-form">
            @Html.AntiForgeryToken()

            <input type="hidden" name="AssessmentAction" value="StartLevelTest" />

            @if (Model.HasExistingSession)
            {
                <input type="hidden" name="SessionId" value="@Model.SessionId" />
                <input type="hidden" name="LanguageId" value="@Model.LanguageId" />

                <p class="quizlearn-description">
                    A szintfelmérő a korábban kiválasztott nyelv alapján indul.
                </p>
            }
            else
            {
                <div class="quizlearn-field">
                    <label for="LanguageId">Milyen nyelvből szeretnél szintfelmérőt?</label>

                    <select id="LanguageId" name="LanguageId" class="quizlearn-select">
                        <option value="">-- Válassz nyelvet --</option>

                        @foreach (var language in Model.Languages)
                        {
                            <option value="@language.LanguageId">@language.Name</option>
                        }
                    </select>
                </div>
            }

            <button type="submit" class="quizlearn-button">
                Szintfelmérő indítása
            </button>
        </form>
    </div>
</div>

<style>
    .quizlearn-wrapper {
        background: #f3f6fb;
        padding: 32px 16px;
        display: flex;
        justify-content: center;
    }

    .quizlearn-card {
        width: 100%;
        max-width: 720px;
        background: #ffffff;
        border-radius: 10px;
        padding: 40px 48px;
        box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.18);
        text-align: center;
    }

    .quizlearn-step-indicator {
        display: flex;
        justify-content: center;
        gap: 18px;
        margin-bottom: 24px;
    }

        .quizlearn-step-indicator span {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #d8dee8;
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            font-weight: 700;
            box-shadow: 0 4px 0 rgba(0, 0, 0, 0.15);
        }

        .quizlearn-step-indicator .active {
            background: #142943;
        }

    .quizlearn-title {
        font-size: 34px;
        line-height: 1.25;
        color: #142943;
        margin-bottom: 14px;
        font-weight: 700;
    }

    .quizlearn-description {
        font-size: 18px;
        color: #26384d;
        margin-bottom: 28px;
    }

    .quizlearn-form {
        max-width: 560px;
        margin: 0 auto;
    }

    .quizlearn-field {
        text-align: left;
        margin-bottom: 22px;
    }

        .quizlearn-field label {
            display: block;
            font-weight: 700;
            color: #142943;
            margin-bottom: 8px;
        }

    .quizlearn-select {
        width: 100%;
        border: 2px solid #233b5b;
        border-radius: 7px;
        padding: 12px 14px;
        font-size: 17px;
        background: #ffffff;
        box-sizing: border-box;
    }

    .quizlearn-button {
        background: #142943;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 12px 22px;
        font-size: 19px;
        cursor: pointer;
    }

        .quizlearn-button:hover {
            background: #1d3b60;
        }

    .quizlearn-error {
        max-width: 560px;
        margin: 0 auto 18px auto;
        background: #ffe8e8;
        color: #8a1f1f;
        border: 1px solid #e0a5a5;
        border-radius: 6px;
        padding: 10px 14px;
        text-align: left;
    }

    @@media (max-width: 640px) {
        .quizlearn-card {
            padding: 28px 20px;
        }

        .quizlearn-title {
            font-size: 27px;
        }
    }
</style>