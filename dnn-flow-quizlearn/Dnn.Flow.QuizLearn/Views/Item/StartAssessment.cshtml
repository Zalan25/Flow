@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Dnn.Flow.QuizLearn.Models.AssessmentStartViewModel>

<div class="quizlearn-assessment-start">
    <h2>Szintfelmérő indítása</h2>

    <p>
        A szintfelmérő segít meghatározni, hogy jelenleg milyen nyelvi szinten vagy.
    </p>

    @if (!ViewData.ModelState.IsValid)
    {
    <div class="alert alert-danger">
        @foreach (var state in ViewData.ModelState.Values)
            {
                foreach (var error in state.Errors)
                {
        <div>@error.ErrorMessage</div>
                }
            }
    </div>
    }

    <form method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="AssessmentAction" value="StartLevelTest" />

        @if (Model.HasExistingSession)
        {
        <input type="hidden" name="SessionId" value="@Model.SessionId" />
        <input type="hidden" name="LanguageId" value="@Model.LanguageId" />

        <p>
            A szintfelmérő a korábban kiválasztott nyelv alapján indul.
        </p>
        }
        else
        {
        <div class="form-group">
            <label for="LanguageId">Milyen nyelvből szeretnél szintfelmérőt?</label>

            <select id="LanguageId" name="LanguageId" class="form-control">
                <option value="">-- Válassz nyelvet --</option>

                @foreach (var language in Model.Languages)
                    {
                <option value="@language.LanguageId">
                    @language.Name
                </option>
                    }
            </select>
        </div>
        }

        <button type="submit" class="btn btn-primary">
            Szintfelmérő indítása
        </button>
    </form>
</div>