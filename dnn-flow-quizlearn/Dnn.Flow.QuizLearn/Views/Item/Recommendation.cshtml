@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<List<Dnn.Flow.QuizLearn.Models.RecommendationRuleInfo>>
@using System.Web
@using Dnn.Flow.QuizLearn.Models

<link rel="stylesheet" href="/DesktopModules/YourRfProjects/dnn-flow-quizlearn/Dnn.Flow.QuizLearn/css/recommendation.css" />

@{
    RecommendationRuleInfo firstRule = null;

    if (Model != null && Model.Count > 0)
    {
        firstRule = Model[0];
    }

    var productTitle = "Személyre szabott tanulási ajánlat";
    var productImageUrl = "/DesktopModules/YourRfProjects/dnn-flow-quizlearn/Dnn.Flow.QuizLearn/images/recommendation-default.jpg";
    var productUrl = "#";

    if (firstRule != null)
    {
        var tag = firstRule.HotcakesTag;

        if (!string.IsNullOrWhiteSpace(tag))
        {
            productTitle = tag.Replace("-", " ");
            productUrl = "/Search?search=" + HttpUtility.UrlEncode(tag);
        }
    }
}

<div class="ql-page">
    <div class="ql-result-card">
        <h1 class="ql-result-title">Neked ajánljuk:</h1>

        @if (firstRule == null)
        {
        <div class="ql-empty-state">
            <div class="ql-empty-icon">?</div>
            <h2>Nincs találat</h2>
            <p>A megadott válaszok alapján jelenleg nem található megfelelő ajánlási szabály.</p>
        </div>
        }
        else
        {
        <div class="ql-product-card">
            <div class="ql-product-image-wrap">
                <img class="ql-product-image" src="@productImageUrl" alt="Ajánlott tananyag" />
            </div>

            <h2 class="ql-product-title">@productTitle</h2>

            <a class="ql-primary-button" href="@productUrl">Kosárba teszem</a>
        </div>
        }
    </div>
</div>
