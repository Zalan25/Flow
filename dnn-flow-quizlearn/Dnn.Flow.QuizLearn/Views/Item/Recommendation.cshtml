@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<IEnumerable<Dnn.Flow.QuizLearn.Models.Item>>

@using System.Text.RegularExpressions
@using DotNetNuke.Web.Mvc.Helpers

@using System.Linq
@model IEnumerable<Dnn.Flow.QuizLearn.Models.RecommendationRuleInfo>

    @{
    ViewBag.Title = "Ajánlási eredmény";
    }

    <h2>Ajánlási eredmény</h2>

    <p><strong>Session ID:</strong> @ViewBag.SessionId</p>
    <p><strong>Talált szabályok száma:</strong> @ViewBag.RuleCount</p>

    @if (Model == null || !Model.Any())
{
    <div style="padding:10px; border:1px solid #ccc;">
        Nincs találat a megadott paraméterekre.
    </div>
}
else
{
    <table class="dnnTableDisplay" style="width:100%; border-collapse:collapse;">
        <thead>
            <tr>
                <th>Rule ID</th>
                <th>Szint</th>
                <th>Készség</th>
                <th>Tempó</th>
                <th>Match mód</th>
                <th>SKU</th>
                <th>Kategória</th>
                <th>Tag</th>
                <th>Min</th>
                <th>Max</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rule in Model)
        {
            <tr>
                <td>@rule.RecommendationRuleId</td>
                <td>@rule.QuestionLevelId</td>
                <td>@rule.SkillTypeId</td>
                <td>@rule.PaceTypeId</td>
                <td>@rule.MatchMode</td>
                <td>@rule.HotcakesProductSKU</td>
                <td>@rule.HotcakesCategoryKey</td>
                <td>@rule.HotcakesTag</td>
                <td>@rule.MinProducts</td>
                <td>@rule.MaxProducts</td>
            </tr>
        }
        </tbody>
    </table>
}
